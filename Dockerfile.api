# Build
FROM golang:1.22-alpine AS builder
WORKDIR /src
RUN apk add --no-cache git ca-certificates
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /out/pmas-api ./cmd/api

# Run
FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata \
  && adduser -D -H -u 10001 appuser
WORKDIR /app
COPY --from=builder /out/pmas-api /app/pmas-api
USER appuser
EXPOSE 8080
ENV PORT=8080
ENTRYPOINT ["/app/pmas-api"]
