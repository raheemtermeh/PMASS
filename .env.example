# Copy to .env and fill real values. Never commit .env.

APP_ENV=development
PORT=8080

# postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_URL=

# Min 32 random characters — never reuse placeholders
JWT_SECRET=

# Any long random string; used as AES-GCM key material for credential vault
CREDENTIALS_ENCRYPTION_KEY=

# Comma-separated exact origins (scheme + host + port).
# Use * to temporarily allow any Origin (reflects request Origin; not for long-term prod).
CORS_ALLOWED_ORIGINS=*
